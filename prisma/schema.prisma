// The Serene Path — data model (source of truth, APP_SPEC §8).
// Stage 0 commits the subset the early stages need; Appointment (Stage 6),
// Payment (Stage 8) and Review (Stage 9) are added ADDITIVELY when their stage
// begins, keeping these shapes. Ids are cuid; instants are stored UTC; money is
// Decimal; localized text is { en, he, fr } JSON.
//
// NOTE (sensitive data, §11): IntakeSession.messages holds mental-health chat
// content. Field-level encryption / access auditing is deferred to the Stage 9
// security pass per BUILD_PLAN; flagged here so it isn't forgotten.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  CLIENT
  THERAPIST
  ADMIN
}

enum TherapistStatus {
  DRAFT
  PENDING
  VERIFIED
  SUSPENDED
}

enum IntakeState {
  GREETING
  GATHER
  MIRROR
  CONFIRM
  MATCH
  CLARIFY
  PRESENT_OPTIONS
  FOLLOWUP
  CRISIS
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

model User {
  id        String   @id @default(cuid())
  role      Role     @default(CLIENT)
  email     String   @unique
  name      String?
  // bcrypt hash for email/password sign-in; null for social/passwordless users.
  passwordHash String? @map("password_hash")
  locale    String   @default("en")
  timezone  String   @default("Asia/Jerusalem")
  therapist TherapistProfile?
  appointments Appointment[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TherapistProfile {
  id           String                  @id @default(cuid())
  user         User                    @relation(fields: [userId], references: [id])
  userId       String                  @unique
  title        String
  bio          Json // { en, he, fr }
  skills       String[]
  modalities   String[]
  languages    String[]
  credentials  String?
  photoUrl     String?
  sessionPrice Decimal                 @db.Decimal(10, 2)
  status       TherapistStatus         @default(DRAFT)
  gender       Gender? // for the intake's optional gender-preference filter (§matching)
  rating       Float                   @default(0)
  reviewCount  Int                     @default(0)
  rules        AvailabilityRule[]
  exceptions   AvailabilityException[]
  appointments Appointment[]
  createdAt    DateTime                @default(now())
  updatedAt    DateTime                @updatedAt
}

model AvailabilityRule {
  id          String           @id @default(cuid())
  therapist   TherapistProfile @relation(fields: [therapistId], references: [id])
  therapistId String
  weekday     Int // 0=Sun..6=Sat
  startMinute Int // minutes from local midnight
  endMinute   Int

  @@index([therapistId])
}

model AvailabilityException {
  id          String           @id @default(cuid())
  therapist   TherapistProfile @relation(fields: [therapistId], references: [id])
  therapistId String
  date        DateTime         @db.Date
  isBlocked   Boolean          @default(true)
  startMinute Int?
  endMinute   Int?

  @@index([therapistId])
}

model IntakeSession {
  id                    String      @id @default(cuid())
  userId                String? // null while anonymous, linked on login
  state                 IntakeState @default(GREETING)
  messages              Json // [{ role, content }]
  constraints           Json? // { language?, gender?, modality?, window? }
  suggestedTherapistIds String[]
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt
}

// An appointment (Stage 6). @@unique([therapistId, startUtc]) is the atomic
// double-booking guard: two clients can't take the same therapist's slot — the
// second insert hits the unique constraint (P2002) and fails.
//
// Cancel/rebook: the unique key has no status component, so a CANCELLED row
// still occupies (therapistId, startUtc). getBookedSlots offers a cancelled
// slot as bookable again, so the Stage-6.2 booking path MUST upsert/revive the
// cancelled row at that key (update → PENDING + new client), not plain-insert —
// a plain insert would P2002 on a slot the calendar showed as free.
model Appointment {
  id          String            @id @default(cuid())
  therapist   TherapistProfile  @relation(fields: [therapistId], references: [id])
  therapistId String
  client      User              @relation(fields: [clientId], references: [id])
  clientId    String
  startUtc    DateTime
  endUtc      DateTime
  status      AppointmentStatus @default(PENDING)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@unique([therapistId, startUtc])
  @@index([therapistId])
  @@index([clientId])
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
  NO_SHOW
}
