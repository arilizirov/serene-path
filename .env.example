# Copy to .env and fill in. .env is gitignored; never commit real secrets.

# PostgreSQL — local dev is served by docker-compose.yml (host port 5544).
DATABASE_URL="postgresql://serene:serene@localhost:5544/serene?schema=public"

# --- Added in later stages (placeholders so the surface is documented) ---
# OpenAI API — server-side intake/matching (Stage 3). The owner chose OpenAI
# GPT-5.4 over the spec's Anthropic (see boundaries.yaml server.public: ai).
# Without this key the intake runs on a deterministic stub; set it to go live.
OPENAI_API_KEY=
# Model id — optional, defaults to gpt-5.4. Override here if needed.
# OPENAI_MODEL=gpt-5.4

# Session signing secret. Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
AUTH_SECRET=
